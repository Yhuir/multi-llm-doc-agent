    "repeat_header": true,
    "borders": "all",
    "cell_padding_pt": 4.0
  },
  "image": {
    "default_width_in": 6.0,
    "max_width_in": 7.0,
    "align": "center",
    "caption_enabled_default": true,
    "caption_color": "#000000",
    "grid": {
      "enabled": false,
      "max_images": 4,
      "layout_candidates": [
        "1x1",
        "2x2"
      ],
      "cell_padding_pt": 2.0
    }
  }
