{
  "palette": {
    "title": "#FF0000",
    "h1": "#000000",
    "h2": "#000000",
    "em_blue": "#0070C0",
    "em_green": "#008000",
    "em_red": "#C00000",
    "table_header_fill": "#F2F2F2",
    "caption": "#000000"
  },
  "fonts": {
    "cn": "SimSun",
    "fallback": "Helvetica",
    "mono": "Times New Roman"
  },
  "sizes": {
    "doc_title_pt": 16.0,
    "h1_pt": 16.0,
    "h2_pt": 15.0,
    "h3_pt": 12.0,
    "body_pt": 12.0,
    "caption_pt": 11.0
  },
  "paragraph": {
    "line_spacing": 1.5,
    "first_line_indent_chars": 2,
    "space_before_pt": {
      "h1": 18.0,
      "h2": 12.0,
      "h3": 6.0,
      "body": 0.0
    },
    "space_after_pt": {
      "h1": 18.0,
      "h2": 12.0,
      "h3": 6.0,
      "body": 0.0
